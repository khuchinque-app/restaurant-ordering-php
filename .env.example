# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before starting the container.
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# SQLite database path inside the container (default is fine for Docker)
# DB_PATH=/var/www/html/data/restaurant.db

# Tax rate applied to orders (default 10%)
# TAX_RATE=0.10

# Base URL prefix for asset links (leave empty for same-origin requests)
# APP_URL=
